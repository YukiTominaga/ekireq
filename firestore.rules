rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 投稿
    match /posts/{postId} {
      // 公開: 誰でも読める
      allow read: if true;

      // 作成: ログイン中のユーザーが自分の userId で投稿する場合のみ
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.likesCount == 0
                    && request.resource.data.likedBy.size() == 0
                    && request.resource.data.categories is list
                    && request.resource.data.categories.size() <= 12;

      // 更新: ログイン中のユーザーが「いいね」操作 (likedBy / likesCount) または通報集計 (reportsCount) を行う場合のみ
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['likedBy', 'likesCount', 'reportsCount']);

      // 削除: 投稿者本人のみ
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // 駅別の投稿数集計
    match /stationStats/{stationKey} {
      allow read: if true;
      // postCount は addPost トランザクションで increment されるため、ログイン中ユーザーに書き込みを許可
      allow write: if request.auth != null;
    }

    // 通報
    match /reports/{reportId} {
      // 通報者のプライバシー保護のためクライアントからの参照は禁止
      allow read, update, delete: if false;

      // 作成: ログイン中ユーザーが、自分以外の投稿を 1 回だけ通報できる
      // doc ID は決定的に {postId}_{reporterId} とすることで重複を防ぐ
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.reporterId
                    && reportId == request.resource.data.postId + '_' + request.auth.uid
                    && request.auth.uid != get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.userId
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 50;
    }
  }
}
