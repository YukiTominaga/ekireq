rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 投稿
    match /posts/{postId} {
      // 公開: 誰でも読める
      allow read: if true;

      // 作成: ログイン中のユーザーが自分の userId で投稿する場合のみ
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.likesCount == 0
                    && request.resource.data.likedBy.size() == 0
                    && request.resource.data.reportCount == 0
                    && request.resource.data.reportedBy.size() == 0
                    && request.resource.data.categories is list
                    && request.resource.data.categories.size() <= 12;

      // 更新: ログイン中のユーザーが「いいね」操作 (likedBy / likesCount のみ)
      // または「通報」操作 (reportedBy / reportCount のみ、自分の UID を 1 件追加) を行う場合のみ
      allow update: if request.auth != null
                    && (
                      request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['likedBy', 'likesCount'])
                      ||
                      (
                        request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['reportedBy', 'reportCount'])
                        && !(request.auth.uid in resource.data.reportedBy)
                        && (request.auth.uid in request.resource.data.reportedBy)
                        && request.resource.data.reportCount ==
                           resource.data.reportCount + 1
                      )
                    );

      // 削除: 投稿者本人のみ
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // 駅別の投稿数集計
    match /stationStats/{stationKey} {
      allow read: if true;
      // postCount は addPost トランザクションで increment されるため、ログイン中ユーザーに書き込みを許可
      allow write: if request.auth != null;
    }
  }
}
